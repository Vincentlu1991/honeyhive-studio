      "title": "AnimateDiff Loader"
    }
  },
  "7": {
    "inputs": {
      "model": ["1", 0],
      "motion_model": ["6", 0],
      "latent_image": ["4", 0],
      "frames": 16,
      "overlap": 4,
      "motion_scale": 1.0
