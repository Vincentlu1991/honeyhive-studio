{
  "1": {
    "inputs": {
      "ckpt_name": "v1-5-pruned-emaonly.safetensors"
    },
    "class_type": "CheckpointLoaderSimple",
    "_meta": {
      "title": "Load Checkpoint"
    }
  },
  "2": {
    "inputs": {
      "clip": ["1", 1],
      "text": "masterpiece, best quality, cinematic, a beautiful woman dancing, smooth motion, detailed face, soft lighting"
