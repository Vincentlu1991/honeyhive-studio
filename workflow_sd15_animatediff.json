    "class_type": "KSampler",
    "_meta": {
      "title": "KSampler"
    }
  },
  "5": {
    "inputs": {
      "width": 512,
      "height": 512,
      "length": 16,
      "batch_size": 1
    },
    "class_type": "EmptyLatentVideo",
    "_meta": {
      "title": "Empty Latent Video"
    }
  },
  "6": {
    "inputs": {
      "model_name": "mm_sd_v15_v2.ckpt"
    },
    "class_type": "AnimateDiffLoaderV1",
