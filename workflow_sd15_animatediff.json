    "class_type": "CLIPTextEncode",
    "_meta": {
      "title": "CLIP Text Encode (Positive)"
    }
  },
  "3": {
    "inputs": {
      "clip": ["1", 1],
      "text": "blurry, distorted, low quality, bad hands, static, frozen"
