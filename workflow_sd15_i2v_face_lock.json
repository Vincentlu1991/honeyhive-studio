{
  "1": {
    "inputs": { "ckpt_name": "v1-5-pruned-emaonly.safetensors" },
    "class_type": "CheckpointLoaderSimple",
    "_meta": { "title": "Load Checkpoint" }
  },
  "2": {
    "inputs": {
      "text": "same person as photo, preserve face identity, photorealistic, full body, slight jump upward, charming smile, natural motion, realistic cloth",
      "clip": ["1", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Positive" }
  },
  "3": {
    "inputs": {
      "text": "different person, identity drift, face change, cartoon, anime, cgi, 3d render, doll, plastic skin, deformed face, bad anatomy, extra limbs, ghosting, temporal flicker, jitter, blurry, noisy",
      "clip": ["1", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Negative" }
  },
  "4": {
    "inputs": { "image": "i2v_source.png" },
    "class_type": "LoadImage",
    "_meta": { "title": "Load Image" }
  },
  "13": {
    "inputs": {
      "image": ["4", 0],
      "upscale_method": "lanczos",
      "width": 512,
      "height": 768,
      "crop": "center"
    },
    "class_type": "ImageScale",
    "_meta": { "title": "Image Scale" }
  },
  "11": {
    "inputs": {
      "pixels": ["13", 0],
      "vae": ["1", 2]
    },
    "class_type": "VAEEncode",
    "_meta": { "title": "VAE Encode" }
  },
  "12": {
    "inputs": {
      "samples": ["11", 0],
      "amount": 32
    },
    "class_type": "RepeatLatentBatch",
    "_meta": { "title": "Repeat Latent Batch" }
  },
  "5": {
    "inputs": { "model_name": "mm_sd_v15_v2.ckpt" },
    "class_type": "ADE_LoadAnimateDiffModel",
    "_meta": { "title": "Load AnimateDiff Model" }
  },
  "6": {
    "inputs": { "motion_model": ["5", 0] },
    "class_type": "ADE_ApplyAnimateDiffModelSimple",
    "_meta": { "title": "Apply AnimateDiff Model" }
  },
  "7": {
    "inputs": {
      "model": ["1", 0],
      "beta_schedule": "autoselect",
      "m_models": ["6", 0]
    },
    "class_type": "ADE_UseEvolvedSampling",
    "_meta": { "title": "Use Evolved Sampling" }
  },
  "8": {
    "inputs": {
      "seed": 42,
      "steps": 25,
      "cfg": 7.0,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 0.65,
      "model": ["7", 0],
      "positive": ["2", 0],
      "negative": ["3", 0],
      "latent_image": ["12", 0]
    },
    "class_type": "KSampler",
    "_meta": { "title": "KSampler" }
  },
  "9": {
    "inputs": {
      "samples": ["8", 0],
      "vae": ["1", 2]
    },
    "class_type": "VAEDecode",
    "_meta": { "title": "VAE Decode" }
  },
  "10": {
    "inputs": {
      "images": ["9", 0],
      "frame_rate": 4,
      "loop_count": 0,
      "filename_prefix": "sd15_i2v_face_lock",
      "format": "video/h264-mp4",
      "pingpong": false,
      "save_output": true
    },
    "class_type": "VHS_VideoCombine",
    "_meta": { "title": "Video Combine" }
  }
}
