{
  "1": {
    "inputs": {
      "image": "照片.jpg",
      "upload": "image"
    },
    "class_type": "LoadImage",
    "_meta": {
      "title": "加载图片"
    }
  },
  "2": {
    "inputs": {
      "ckpt_name": "ltxv-2b-0.9.8-distilled.safetensors"
    },
    "class_type": "CheckpointLoaderSimple",
    "_meta": {
      "title": "LTXV模型加载器"
    }
  },
  "3": {
    "inputs": {
      "text": "person in the photo making various funny faces, realistic facial expressions, natural movement, smooth animation, high quality",
      "clip": ["2", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {
      "title": "正面提示词"
    }
  },
  "4": {
    "inputs": {
      "text": "blurry, distorted, static, stiff, unnatural, low quality, artifacts",
      "clip": ["2", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {
      "title": "负面提示词"
    }
  },
  "5": {
    "inputs": {
      "image": ["1", 0],
      "positive": ["3", 0],
      "negative": ["4", 0],
      "vae": ["2", 2],
      "width": 704,
      "height": 480,
      "length": 25,
      "batch_size": 1,
      "strength": 1.0
    },
    "class_type": "LTXVImgToVideo",
    "_meta": {
      "title": "LTXV图像转视频条件"
    }
  },
  "6": {
    "inputs": {
      "model": ["2", 0],
      "seed": 42,
      "steps": 8,
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "positive": ["5", 0],
      "negative": ["5", 1],
      "latent_image": ["5", 2],
      "denoise": 1.0
    },
    "class_type": "KSampler",
    "_meta": {
      "title": "LTXV采样器"
    }
  },
  "7": {
    "inputs": {
      "samples": ["6", 0],
      "vae": ["2", 2]
    },
    "class_type": "VAEDecode",
    "_meta": {
      "title": "VAE解码"
    }
  },
  "8": {
    "inputs": {
      "frame_rate": 24,
      "loop_count": 0,
      "filename_prefix": "ltxv_img2video_faces",
      "format": "video/h264-mp4",
      "pingpong": false,
      "save_output": true,
      "images": ["7", 0]
    },
    "class_type": "VHS_VideoCombine",
    "_meta": {
      "title": "视频合并输出"
    }
  }
}
